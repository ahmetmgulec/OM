# SpacetimeDB connection
# Yerel sunucu için:
# VITE_SPACETIMEDB_HOST=ws://localhost:3000
# Maincloud (yayın) için:
VITE_SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
VITE_SPACETIMEDB_DB_NAME=mytestapp

# SpacetimeAuth (recommended) - OIDC auth via auth.spacetimedb.com
# Enable SpacetimeAuth in your module dashboard, create a client, add redirect URIs:
#   http://localhost:5173/callback, https://your-app.vercel.app/callback
# When set, replaces email/Google auth with SpacetimeAuth (Google, GitHub, etc.)
VITE_SPACETIMEAUTH_CLIENT_ID=

# Google OAuth - used only when SpacetimeAuth is NOT configured
# Leave empty or omit to use email/password only
VITE_GOOGLE_CLIENT_ID=

# Voice debug - enable in production for troubleshooting (?voice_debug in URL also works)
# VITE_VOICE_DEBUG=true
